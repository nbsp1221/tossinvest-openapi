{
  "name": "tossinvest-openapi",
  "version": "0.1.0",
  "description": "Unofficial TypeScript SDK for Toss Securities Open API",
  "license": "MIT",
  "keywords": [
    "api-client",
    "finance",
    "korean-stock",
    "openapi",
    "sdk",
    "stock-trading",
    "toss",
    "toss-securities",
    "tossinvest",
    "trading-api",
    "typescript"
  ],
  "homepage": "https://github.com/nbsp1221/tossinvest-openapi#readme",
  "bugs": {
    "url": "https://github.com/nbsp1221/tossinvest-openapi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbsp1221/tossinvest-openapi.git",
    "directory": "packages/typescript"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "examples",
    "LICENSE",
    "README.md",
    "README.en.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --target node22",
    "check:types": "openapi-typescript ../../spec/upstream/openapi.json -o src/generated/openapi.ts --default-non-nullable false --check",
    "check:version": "node scripts/sync-version.mjs --check",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "generate:types": "openapi-typescript ../../spec/upstream/openapi.json -o src/generated/openapi.ts --default-non-nullable false",
    "lint": "eslint .",
    "test": "vitest run test/unit test/integration",
    "test:integration": "vitest run test/integration",
    "test:unit": "vitest run test/unit",
    "sync:version": "node scripts/sync-version.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
